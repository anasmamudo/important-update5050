        function printAdminMembersRegistry() {
            const targetArea = document.getElementById('print-area');
            let rowsHtml = '';
            
            APP_MEMBERS.filter(m => m.role !== 'admin').forEach((m, idx) => {
                rowsHtml += `
                    <tr style="border-bottom: 1px solid #ddd; font-size: 12px;">
                        <td style="padding: 10px; text-align: center;">${idx + 1}</td>
                        <td style="padding: 10px; font-weight: bold;">${m.name}</td>
                        <td style="padding: 10px; color: #047857;">₦${(m.deposit || 0).toLocaleString()}</td>
